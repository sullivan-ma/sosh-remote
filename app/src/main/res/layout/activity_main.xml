<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOSH REMOTE"
            android:textColor="#E8531A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Décodeur TV · WiFi"
            android:textColor="#5A5A7A"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- Config Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16161F"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙ CONFIGURATION"
                android:textColor="#5A5A7A" android:textSize="10sp" android:letterSpacing="0.2"
                android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <EditText android:id="@+id/ip_input"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:hint="IP décodeur (192.168.1.x)"
                    android:textColor="#E8E8F0" android:textColorHint="#5A5A7A"
                    android:background="#1C1C28" android:padding="8dp"
                    android:textSize="13sp" android:inputType="text"
                    android:layout_marginEnd="8dp"/>

                <Button android:id="@+id/btn_connect"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="CONNECTER"
                    android:textColor="#FFFFFF" android:backgroundTint="#E8531A"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Status -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="10dp">
                <View android:id="@+id/status_dot"
                    android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_grey"
                    android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/status_text"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Non connecté"
                    android:textColor="#5A5A7A" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Scan Button -->
            <Button android:id="@+id/btn_scan"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="🔍  Rechercher les décodeurs sur le réseau"
                android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"
                android:textSize="12sp"
                android:layout_marginTop="10dp"/>

            <!-- Scan Panel -->
            <ScrollView android:id="@+id/scan_panel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView android:id="@+id/scan_status"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Scan..." android:textColor="#5A5A7A" android:textSize="12sp"/>
                        <TextView android:id="@+id/scan_progress_text"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0/254" android:textColor="#5A5A7A" android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/scan_progress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="254" android:progress="0"
                        android:progressTint="#E8531A"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:id="@+id/scan_results"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </ScrollView>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💡 IP aussi visible sur votre Livebox : 192.168.1.1 → Équipements connectés"
                android:textColor="#5A5A7A" android:textSize="11sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- REMOTE BODY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111118"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Power + Mute -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="12dp">
                <Button android:id="@+id/btn_power"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:text="⏻" android:textSize="20sp"
                    android:textColor="#E8531A" android:backgroundTint="#1E0E0A"
                    android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btn_mute"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:text="🔇" android:textSize="18sp"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"/>
            </LinearLayout>

            <!-- Quick access -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ACCÈS RAPIDE" android:textColor="#5A5A7A" android:textSize="10sp"
                android:letterSpacing="0.2" android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btn_home" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:text="🏠 Accueil"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="11sp"
                    android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_guide" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:text="📅 Guide"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="11sp"
                    android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_vod" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:text="🎬 VOD"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="11sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E1E2E" android:layout_marginBottom="14dp"/>

            <!-- Navigation Cross -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NAVIGATION" android:textColor="#5A5A7A" android:textSize="10sp"
                android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

            <GridLayout android:layout_width="180dp" android:layout_height="180dp"
                android:rowCount="3" android:columnCount="3" android:layout_marginBottom="8dp">
                <Space android:layout_width="60dp" android:layout_height="60dp"
                    android:layout_row="0" android:layout_column="0"/>
                <Button android:id="@+id/btn_up" android:layout_row="0" android:layout_column="1"
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:text="▲" android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"/>
                <Space android:layout_width="60dp" android:layout_height="60dp"
                    android:layout_row="0" android:layout_column="2"/>
                <Button android:id="@+id/btn_left" android:layout_row="1" android:layout_column="0"
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:text="◀" android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"/>
                <Button android:id="@+id/btn_ok" android:layout_row="1" android:layout_column="1"
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:text="OK" android:textColor="#FFFFFF" android:backgroundTint="#E8531A"
                    android:textStyle="bold"/>
                <Button android:id="@+id/btn_right" android:layout_row="1" android:layout_column="2"
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:text="▶" android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"/>
                <Space android:layout_width="60dp" android:layout_height="60dp"
                    android:layout_row="2" android:layout_column="0"/>
                <Button android:id="@+id/btn_down" android:layout_row="2" android:layout_column="1"
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:text="▼" android:textColor="#E8E8F0" android:backgroundTint="#1C1C28"/>
                <Space android:layout_width="60dp" android:layout_height="60dp"
                    android:layout_row="2" android:layout_column="2"/>
            </GridLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btn_back" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:text="↩ Retour"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_menu_btn" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:text="☰ Menu"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="12sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E1E2E" android:layout_marginBottom="14dp"/>

            <!-- Volume / Channel -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="VOLUME" android:textColor="#5A5A7A" android:textSize="9sp"
                        android:letterSpacing="0.15" android:layout_marginBottom="4dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <Button android:id="@+id/btn_vol_down" android:layout_width="52dp" android:layout_height="36dp"
                            android:text="🔉" android:backgroundTint="#1C1C28" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn_vol_up" android:layout_width="52dp" android:layout_height="36dp"
                            android:text="🔊" android:backgroundTint="#1C1C28"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CHAÎNE" android:textColor="#5A5A7A" android:textSize="9sp"
                        android:letterSpacing="0.15" android:layout_marginBottom="4dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <Button android:id="@+id/btn_ch_down" android:layout_width="52dp" android:layout_height="36dp"
                            android:text="−" android:textSize="18sp" android:backgroundTint="#1C1C28"
                            android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn_ch_up" android:layout_width="52dp" android:layout_height="36dp"
                            android:text="+" android:textSize="18sp" android:backgroundTint="#1C1C28"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E1E2E" android:layout_marginBottom="14dp"/>

            <!-- Media Controls -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LECTURE" android:textColor="#5A5A7A" android:textSize="10sp"
                android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btn_prev" android:layout_width="40dp" android:layout_height="36dp"
                    android:text="⏮" android:backgroundTint="#1C1C28" android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btn_rew" android:layout_width="40dp" android:layout_height="36dp"
                    android:text="⏪" android:backgroundTint="#1C1C28" android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btn_play" android:layout_width="52dp" android:layout_height="40dp"
                    android:text="⏯" android:backgroundTint="#1C1C28" android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btn_ffw" android:layout_width="40dp" android:layout_height="36dp"
                    android:text="⏩" android:backgroundTint="#1C1C28" android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btn_next" android:layout_width="40dp" android:layout_height="36dp"
                    android:text="⏭" android:backgroundTint="#1C1C28"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btn_stop" android:layout_width="0dp" android:layout_height="34dp"
                    android:layout_weight="1" android:text="⏹ Stop"
                    android:textColor="#E8E8F0" android:backgroundTint="#1C1C28" android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_rec" android:layout_width="0dp" android:layout_height="34dp"
                    android:layout_weight="1" android:text="⏺ Enreg."
                    android:textColor="#E84444" android:backgroundTint="#1C1C28" android:textSize="12sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E1E2E" android:layout_marginBottom="14dp"/>

            <!-- Color Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btn_red" android:layout_width="0dp" android:layout_height="26dp"
                    android:layout_weight="1" android:backgroundTint="#C0392B" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_green" android:layout_width="0dp" android:layout_height="26dp"
                    android:layout_weight="1" android:backgroundTint="#27AE60" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_yellow" android:layout_width="0dp" android:layout_height="26dp"
                    android:layout_weight="1" android:backgroundTint="#C9870A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_blue" android:layout_width="0dp" android:layout_height="26dp"
                    android:layout_weight="1" android:backgroundTint="#2980B9"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E1E2E" android:layout_marginBottom="14dp"/>

            <!-- Numpad -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CHAÎNE DIRECTE" android:textColor="#5A5A7A" android:textSize="10sp"
                android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:rowCount="4" android:columnCount="3" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="1"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="2"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="3"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="4"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="5"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="6"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="7"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="8"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="9"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Button android:id="@+id/btn_text" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="TXT"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="12sp"/>
                <Button android:id="@+id/btn_0" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_columnWeight="1" android:text="0"
                    android:textColor="#E8E8F0" android:backgroundTint="#1E1E2E" android:textSize="16sp"/>
                <Space android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1"/>
            </GridLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
